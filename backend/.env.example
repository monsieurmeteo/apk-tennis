# Supabase Configuration
# Trouvez ces informations dans les "Project Settings -> API" et "Database" de votre tableau de bord Supabase

SUPABASE_URL="https://votre-id-projet.supabase.co"
SUPABASE_KEY="votre-anon-public-key"

# Chaine de connexion Postgres (Pour l'ingestion massive via SQLAlchemy)
DATABASE_URL="postgresql://postgres.[votre-id-projet]:[votre-mot-de-passe]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"
